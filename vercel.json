{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "redirects": [
    { "source": "/blog", "destination": "/blog/", "permanent": true },
    { "source": "/blog/:slug", "destination": "/blog/:slug/", "permanent": true }
  ]
}
