# Canonical site URL (Open Graph, metadata)
NEXT_PUBLIC_SITE_URL=https://intellibridge.in

# Supabase — get these from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated admin emails (who can access /admin/)
# Leave empty to allow any signed-in user during initial setup
NEXT_PUBLIC_ADMIN_EMAILS=your-email@example.com

# Sanity (public read — safe for NEXT_PUBLIC)
# Use the same project + dataset in hosting (Vercel etc.) as on your machine.
# This app uses static export: the blog list is baked in at build time. After you
# publish a new post in Sanity, run a new production deploy so /blog includes it.
NEXT_PUBLIC_SANITY_PROJECT_ID=hiyebjbq
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
